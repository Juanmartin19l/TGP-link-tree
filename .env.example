# NocoDB API token (read-only recommended for frontend use)
VITE_NOCODB_TOKEN=your_nocodb_token_here

# NocoDB base URL (without trailing slash)
VITE_NOCODB_BASE_URL=http://your-nocodb-host

# NocoDB source / base / table identifiers
VITE_NOCODB_SOURCE_ID=your_source_id
VITE_NOCODB_BASE_ID=your_base_id
VITE_NOCODB_TABLE_ID=your_table_id
